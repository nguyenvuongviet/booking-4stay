# ============================================
# ================ SERVER =====================
# ============================================
PORT=3069
NODE_ENV=development
CLIENT_URL="your_client_url"

# ============================================
# ================ DATABASE ===================
# ============================================
DATABASE_URL="mysql://username:password@localhost:3306/db_booking_homestay?timezone=+07:00"
# Bỏ qua trigger database (Đặt thành true khi sử dụng TiDB Cloud)
SKIP_TRIGGERS="true"

# ============================================
# ================= AUTH ======================
# ============================================
ACCESS_TOKEN_SECRET="your_access_secret"
ACCESS_TOKEN_EXPIRES="1d"

REFRESH_TOKEN_SECRET="your_refresh_secret"
REFRESH_TOKEN_EXPIRES="7d"

# ============================================
# ================ EMAIL SMTP =================
# ============================================
SENDER_EMAIL="your_email_here"
SENDER_PASSWORD="your_email_app_password"

# Cấu hình Resend Email API (Khuyên dùng khi chạy trên Render Free để không bị chặn SMTP)
RESEND_API_KEY="your_resend_api_key_here"
RESEND_FROM_EMAIL="4Stay Support <onboarding@resend.dev>"

# Email nhận thông báo nội bộ cho admin
ADMIN_EMAIL="your_admin_email_here"

# ============================================
# ================ GOOGLE LOGIN & AI =========
# ============================================
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GEMINI_API_KEY="your_gemini_api_key"
GEMINI_MODEL="gemini-2.0-flash-lite"

# ============================================
# ================ CLOUDINARY ================
# ============================================
CLOUDINARY_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
CLOUDINARY_BASE_URL="https://res.cloudinary.com/your_cloud_name/image/upload/"

# ============================================
# ================= PAYOS =====================
# ============================================
PAYOS_CLIENT_ID="your_payos_client_id"
PAYOS_API_KEY="your_payos_api_key"
PAYOS_CHECKSUM_KEY="your_payos_checksum_key"

# ============================================
# ============= WEB PUSH NOTI (VAPID) ========
# ============================================
VAPID_PUBLIC_KEY="your_vapid_public_key"
VAPID_PRIVATE_KEY="your_vapid_private_key"
VAPID_SUBJECT="mailto:your_email_here"